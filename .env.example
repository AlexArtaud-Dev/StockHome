JWT_SECRET=change_me_in_production
JWT_REFRESH_SECRET=change_me_refresh_secret
DB_PATH=./data/stockhome.db
UPLOAD_DIR=./data/uploads
PORT=3001
MAX_CONTAINER_DEPTH=3

# Admin account — created on first start if no admin exists
# Set FIRST_LAUNCH=true to force a password reset on next start (then set back to false)
ADMIN_EMAIL=admin@example.com
FIRST_LAUNCH=true

# Email / SMTP (leave blank to use console mock)
# Gmail: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587, SMTP_SECURE=false (use App Password)
# Gmail SSL: SMTP_PORT=465, SMTP_SECURE=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=user@example.com
SMTP_PASS=your_app_password
SMTP_FROM=StockHome <user@example.com>

# Frontend URL (used in email links — must match where your frontend runs)
APP_URL=http://localhost:3000
